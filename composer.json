{
    "name": "mll-lab/laravel-comment",
    "description": "Just another comment system for your awesome Laravel project.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel-comment"
    ],
    "authors": [
        {
            "name": "Mehmet Aydin Bahadir",
            "email": "mehmet.aydin.bahadir@gmail.com"
        },
        {
            "name": "Benedikt Franke",
            "email": "benedikt@franke.tech"
        }
    ],
    "homepage": "https://github.com/mll-lab/laravel-comment",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10 || ^11 || ^12 || ^13",
        "illuminate/support": "^10 || ^11 || ^12 || ^13"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2",
        "fakerphp/faker": "^1.8",
        "orchestra/testbench": "^8 || ^9 || ^10 || ^11",
        "phpunit/phpunit": "^10 || ^11 || ^12"
    },
    "autoload": {
        "psr-4": {
            "Actuallymab\\LaravelComment\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Actuallymab\\LaravelComment\\Tests\\": "tests"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "kylekatarnls/update-helper": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "\\Actuallymab\\LaravelComment\\LaravelCommentServiceProvider"
            ]
        }
    }
}
